# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Set to "mock" to use static mock data instead of live RSS
INGEST_MODE=live

# Set to "mock" to skip real LLM calls (uses deterministic mock scores)
CLASSIFIER_MODE=live

# SQLite DB path (relative to backend/)
DATABASE_URL=sqlite:///./jobs.db

# How many days old a posting can be before we drop it
MAX_POSTING_AGE_DAYS=30

# Minimum trust score to surface in the feed
MIN_TRUST_SCORE=70
